generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

model Page {
  id          String   @id @default(cuid())
  title       String   // Nom du personnage (ex: "Sophie Foster")
  slug        String   @unique // Pour l'URL (ex: "sophie-foster")
  category    Category // Utilisation d'un Enum pour la sécurité
  
  imageCard   String   // Miniature pour la grille
  imageFull   String?  // Grande image (optionnelle)
  
  abilities   String[]
  family      String[]
  content     String[] // Un gros bloc de texte pour l'histoire
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  CYGNE_NOIR
  ANTAGONISTES
  CONSEIL
  MENTOR
  PROTAGONISTES
  AUTRE
}